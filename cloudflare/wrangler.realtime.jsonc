{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "susnoodle-rooms",
  "main": "./realtime-worker.ts",
  "compatibility_date": "2026-04-28",
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "RoomDurableObject"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RoomDurableObject"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
